{
    "name": "rybbit.ts",
    "version": "1.0.10",
    "description": "TypeScript wrapper for the rybbit.com API to be used on server runtimes such as Node.",
    "keywords": [
        "rybbit",
        "api",
        "sdk",
        "node",
        "typescript",
        "analytics"
    ],
    "type": "module",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "license": "MIT",
    "homepage": "https://github.com/jacobhumston/rybbit.ts",
    "repository": {
        "url": "https://github.com/jacobhumston/rybbit.ts"
    },
    "scripts": {
        "format": "bun x prettier --write --cache .",
        "compile": "del dist/ && bun x tsc && bun run tools/bundle.ts",
        "docs": "del docs/ && bun x typedoc src/index.ts --options typedoc.json && bun x prettier --write --ignore-path null docs/"
    },
    "devDependencies": {
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "@types/bun": "^1.3.10",
        "@types/node": "^25.3.5",
        "del-cli": "^7.0.0",
        "dts-bundle-generator": "^9.5.1",
        "prettier": "^3.8.1",
        "typedoc": "^0.28.17",
        "typedoc-plugin-mdn-links": "^5.1.1",
        "typedoc-rhineai-theme": "^1.2.0",
        "typescript": "^5.9.3"
    },
    "files": [
        "dist/",
        "LICENSE",
        "README.md",
        "package.json"
    ]
}
